  "2": "# Import các lớp cần thiết từ Google Agent Developer Kit",
  "3": "(ADK)",
  "4": "from google.adk.agents import LlmAgent",
  "5": "from google.adk.sessions import InMemorySessionService, Session",
  "6": "from google.adk.runners import Runner",
  "7": "from google.genai.types import Content, Part",
  "8": "# Định nghĩa một LlmAgent với output_key.",
  "9": "greeting_agent = LlmAgent(",
  "10": "name=\"Greeter\",",
  "11": "model=\"gemini-2.0-flash\",",
  "12": "instruction=\"Generate a short, friendly greeting.\",",
  "13": "output_key=\"last_greeting\"",
  "14": ")",
  "15": "# --- Thiết lập Runner và Session ---",
  "16": "app_name, user_id, session_id = \"state_app\", \"user1\", \"session1\"",
  "17": "session_service = InMemorySessionService()",
  "18": "runner = Runner(",
  "19": "agent=greeting_agent,",
  "20": "app_name=app_name,",
  "21": "session_service=session_service",
  "22": ")",
  "23": "session = session_service.create_session(",
  "24": "app_name=app_name,",
  "25": "user_id=user_id,",
  "26": "session_id=session_id",
  "27": ")",
  "28": "print(f\"Initial state: {session.state}\")",
  "29": "# --- Chạy Agent ---",
  "30": "user_message = Content(parts=[Part(text=\"Hello\")])",
  "31": "print(\"\\n--- Running the agent ---\")",
  "32": "for event in runner.run(",
  "33": "user_id=user_id,",
  "34": "session_id=session_id,",
  "35": "new_message=user_message",
  "36": "):",
  "37": "if event.is_final_response():",
  "38": "print(\"Agent responded.\")",
