{
  "0": "\"Vui lòng đặt OPENAI_API_KEY, GOOGLE_CUSTOM_SEARCH_API_KEY, và",
  "1": "GOOGLE_CSE_ID trong file .env của bạn.\"",
  "2": ")",
  "3": "client = OpenAI(api_key=OPENAI_API_KEY)",
  "4": "# --- Bước 1: Phân loại Prompt ---",
  "5": "def classify_prompt(prompt: str) -> dict:",
  "6": "system_message = {",
  "7": "\"role\": \"system\",",
  "8": "\"content\": (",
  "9": "\"Bạn là một bộ phân loại phân tích các prompt người dùng và",
  "10": "trả về một trong ba danh mục ONLY:\\n\\n\"",
  "11": "\"- simple\\n\"",
  "12": "\"- reasoning\\n\"",
  "13": "\"- internet_search\\n\\n\"",
  "14": "\"Quy tắc:\\n\"",
  "15": "\"- Dùng 'simple' cho các câu hỏi thực tế trực tiếp không cần",
  "16": "lập luận hoặc sự kiện hiện tại.\\n\"",
  "17": "\"- Dùng 'reasoning' cho các câu hỏi logic, toán học hoặc suy luận",
  "18": "nhiều bước.\\n\"",
  "19": "\"- Dùng 'internet_search' nếu prompt đề cập đến sự kiện hiện tại,",
  "20": "dữ liệu gần đây, hoặc những gì không có trong dữ liệu huấn luyện của bạn.\\n\\n\"",
  "21": "\"Chỉ trả lời với JSON như:\\n\"",
  "22": "'{ \"classification\": \"simple\" }'",
  "23": "),",
  "24": "}",
  "25": "user_message = {\"role\": \"user\", \"content\": prompt}",
  "26": "response = client.chat.completions.create(",
  "27": "model=\"gpt-4o\", messages=[system_message, user_message],",
  "28": "temperature=1",
  "29": ")",
  "30": "reply = response.choices[0].message.content",
  "31": "return json.loads(reply)",
  "32": "# --- Bước 2: Google Search ---",
  "33": "def google_search(query: str, num_results=1) -> list:",
  "34": "url = \"https://www.googleapis.com/customsearch/v1\"",
  "35": "params = {",
  "36": "\"key\": GOOGLE_CUSTOM_SEARCH_API_KEY,",
  "37": "\"cx\": GOOGLE_CSE_ID,",
  "38": "\"q\": query,",
  "39": "\"num\": num_results,",
  "40": "}",
  "41": "7"
}
