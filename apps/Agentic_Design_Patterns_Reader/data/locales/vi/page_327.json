  "18": "# --- 1. Hệ Thống Quản Lý Nhiệm Vụ ---",
  "19": "class Task(BaseModel):",
  "20": "\"\"\"Đại diện cho một nhiệm vụ đơn lẻ trong hệ thống.\"\"\"",
  "21": "id: str",
  "22": "description: str",
  "23": "priority: Optional[str] = None",
  "24": "# P0, P1, P2",
