  "20": "parallel_builder.add_node(\"call_llm_2\", call_llm_2)",
  "21": "parallel_builder.add_node(\"call_llm_3\", call_llm_3)",
  "22": "parallel_builder.add_node(\"aggregator\", aggregator)",
  "23": "# Add edges to connect nodes",
  "24": "parallel_builder.add_edge(START, \"call_llm_1\")",
