  "29": "parallel_builder.add_edge(\"call_llm_3\", \"aggregator\")",
  "30": "parallel_builder.add_edge(\"aggregator\", END)",
  "31": "parallel_workflow = parallel_builder.compile()",
  "32": "# Show workflow",
  "33": "display(Image(parallel_workflow.get_graph().draw_mermaid_png()))",
