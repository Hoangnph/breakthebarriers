# ── Gemini API ──────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_PRICE_PER_1M_TOKENS=0.075

# ── Database ─────────────────────────────────────────────────
# Local (Homebrew Postgres): postgresql://postgres:postgres@localhost:5432/break_the_barriers
# Docker:                    postgresql://postgres:postgres@postgres:5432/break_the_barriers
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/break_the_barriers

# ── Redis ─────────────────────────────────────────────────────
# Local (Homebrew Redis): redis://localhost:6379/0
# Docker:                 redis://redis:6379/0
REDIS_URL=redis://redis:6379/0
